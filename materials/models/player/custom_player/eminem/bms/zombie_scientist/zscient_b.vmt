"VertexLitGeneric"
{
	"$baseTexture" "models\player\custom_player\eminem\bms\zombie_scientist/ZScient_b"
	"$bumpmap" "models\player\custom_player\eminem\bms\zombie_scientist/ZScient_bN"

	"$phong" "1"
	"$phongboost" ".01"
	"$phongalbedotint" "1"
